# --- local_whisper configuration ---
# Copy this file to .env and adjust as needed.

# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=small

# Language code (e.g. de, en) or "auto" to detect per utterance
WHISPER_LANGUAGE=auto

# Compute device: cpu | cuda
DEVICE=cpu

# Compute type: int8 (cpu) | float16 (cuda) | int8_float16
COMPUTE_TYPE=int8

# Push-to-talk hotkey combination (keyboard library syntax)
HOTKEY=ctrl+alt+space

# Per-character delay (seconds) when typing text into the focused field
TYPE_DELAY=0.0

# Microphone sample rate (Hz). Whisper expects 16000.
SAMPLE_RATE=16000
